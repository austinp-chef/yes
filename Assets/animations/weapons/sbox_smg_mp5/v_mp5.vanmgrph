													m_nNodeID = 
													{
														m_id = 1018066440
													}
													m_sNote = ""
													m_commentText = "Add two random fire animations together from the entire 01-09 set, then halve the result to keep the same original intensity. This means ~90 possible variations, and a much more natural-looking randomisation of the animated recoil.\n\nThe first shot is kept more \'unique\' by not using this 50/50 system. The condition for playing the first shot is: not having fired in the past 1000ms."
