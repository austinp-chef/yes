							{
								key = 
								{
									m_id = 1211129735
								}
								value = 
								{
									_class = "CCommentAnimNode"
									m_sName = "Weird bug\?"
									m_vecPosition = [ -64.0, -736.0 ]
									m_nNodeID = 
									{
										m_id = 1211129735
									}
									m_sNote = ""
									m_commentText = "If \"base = reset\" isn\'t ticked on the add node (\"add pushback & fire additives together\") AND the graph starts on the first tick on a non-zero value, then the pushback layer looks like it\'s starting at the first value instead of the default value. Yet the highlighted lines going to the inputs of the Blend 1D nodes don\'t display this...\n\nDiscovery 5mn later: turning off \"lock blend when waning\" fixes it. Thinking that there\'s a phantom 0th tick during which the Blend 1D nodes get first-time initialized at the first value in the list, and would normally instantly get overridden by the default Paramater value before the 1st tick processes and Damping can set in, but the waning-block property activates its effect BEFORE that kicks in."
									m_size = [ 896.0, 352.0 ]
									m_color = [ 139, 0, 0, 255 ]
								}
							},
							{
								key = 
								{
									m_id = 1643255734
								}
								value = 
								{
