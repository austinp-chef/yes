												value = 
												{
													_class = "CCommentAnimNode"
													m_sName = "Unnamed"
													m_vecPosition = [ 512.0, 128.0 ]
													m_nNodeID = 
													{
														m_id = 925481836
													}
													m_sNote = ""
													m_commentText = "Despite reusing shared fire animations, the delta animation that takes care of moving the hand/finger + gun parts (trigger) isn\'t here. This is because the hand and trigger have a separate control for \'non-attack\' uses. This is in the next group. The attack behaviour is handled there; that way I don\'t have to try to make both \'modules\' cooperate with each other..."
													m_size = [ 480.0, 256.0 ]
													m_color = [ 139, 69, 19, 255 ]
												}
											},
											{
												key = 
												{
													m_id = 1018066440
												}
												value = 
												{
													_class = "CCommentAnimNode"
													m_sName = "How this works"
													m_vecPosition = [ -192.0, -448.0 ]
													m_nNodeID = 
													{
														m_id = 1018066440
													}
													m_sNote = ""
													m_commentText = "Add two random fire animations together from the entire 01-09 set, then halve the result to keep the same original intensity. This means ~90 possible variations, and a much more natural-looking randomisation of the animated recoil.\n\nThe first shot is kept more \'unique\' by not using this 50/50 system. The condition for playing the first shot is: not having fired in the past 1000ms."
													m_size = [ 368.0, 320.0 ]
													m_color = [ 186, 85, 211, 255 ]
												}
											},
