											},
											{
												key = 
												{
													m_id = 553744781
												}
												value = 
												{
													_class = "CCommentAnimNode"
													m_sName = "Force thumb off joystick & absolute/additive differences"
													m_vecPosition = [ -160.0, 128.0 ]
													m_nNodeID = 
													{
														m_id = 553744781
													}
													m_sNote = ""
													m_commentText = "This \'absolute\' side (as opposed to the \'additive\' side below) has an early out; if b_joystick=true, then as soon as the ModeSelect_Joystick_1H/2H animation reaches a specific point (cycle>=0.33), start transitioning this side out.\n\nThis is only on this side because the fingers stop moving in it (so it\'s fine), thereby giving back control of the right thumb to the joystick module, while the additive side can continue playing the natural \'recoil\' / \'follow-through\' of the animation.\n\nHowever, while the thumb is off the joystick, I also need to force the joystick back to its neutral/center position!\n\nThe way I\'m doing this is a little bit hacky but I figured it was the most straightforward way to do it.\n\nWhile this \'absolute\' side\'s SM is in a play state, it sets the \'Thumb is forced off joystick\' Tag.\n\nThe SM to the right uses this to force the joystick back to the center."
													m_size = [ 544.0, 480.0 ]
													m_color = [ 38, 42, 47, 255 ]
												}
											},
